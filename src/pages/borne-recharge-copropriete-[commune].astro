---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import CityMap from '../components/CityMap.astro';
import StepsForm from '../components/StepsForm.astro';
import communes from '../data/communes.json';
import { generateCommuneContent, type Commune, getDynamicPrices } from '../lib/contentEngine';
import { getSmartNearbyCommunes } from '../lib/geoLinks';
import config from '../data/config.json';

export async function getStaticPaths() {
  return communes.map((commune) => ({
    params: { commune: commune.slug },
    props: { commune }
  }));
}

interface Props {
  commune: Commune;
}

const { commune } = Astro.props;
const content = generateCommuneContent(commune, 'copropriete');
const nearby = getSmartNearbyCommunes(commune.slug, communes);
const prices = getDynamicPrices(commune);

const title = `Borne de Recharge en Copropriété à ${commune.nom} (${commune.codePostal}) — Installation IRVE`;
const description = content.introParagraph;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes", href: "/communes/" },
  { label: `${commune.nom} (Copropriété)` }
];
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    faqItems={content.faqItems}
    breadcrumbItems={breadcrumbItems}
    communeName={commune.nom}
    zipCode={commune.codePostal}
    cityName={commune.nom}
  />

  <Breadcrumb items={breadcrumbItems} />

  <!-- Hero Banner -->
  <section class="local-hero-banner" style="background: linear-gradient(135deg, #022c22 0%, #064e3b 100%); color: white; padding: 50px 0; border-bottom: 5px solid var(--secondary);">
    <div class="container">
      <div style="max-width: 900px;">
        <span class="hero-badge">🏢 Aides ADVENIR Copropriété 2026</span>
        <h1 style="color: white; font-family: var(--font-heading); font-size: 34px; margin-top: 10px; margin-bottom: 15px; line-height: 1.2;">
          Borne de Recharge en Copropriété à {commune.nom} ({commune.codePostal})
        </h1>
        <p style="color: var(--primary-light); font-size: 16.5px; line-height: 1.5; margin-bottom: 0;">
          {content.introParagraph}
        </p>
      </div>
    </div>
  </section>

  <!-- Local Stats Cards -->
  <section class="local-stats-cards-section" style="padding: 30px 0; background: var(--primary-light); border-bottom: 1px solid var(--border-color);">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px;">
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">💰</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">960 € max</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Aide ADVENIR par place</span>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">⚖️</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">Droit à la Prise</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Garanti par le décret 2020</span>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">🏢</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">{100 - commune.logementsMaison}% Collectif</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Part d'appartements à {commune.nom}</span>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">🔌</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">TVA 5,5%</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Appliquée sur l'installation</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content & Form Layout -->
  <section class="two-column-layout-section" style="padding: 50px 0; background-color: var(--bg);">
    <div class="container">
      <div class="two-column-layout">
        
        <!-- Left Column: Content -->
        <div class="static-main-content" style="background: var(--card-bg); padding: 40px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);">
          
          <!-- Alert Box -->
          <div style="border-left: 4px solid var(--accent); background: var(--primary-light); padding: 15px 20px; border-radius: var(--radius-sm); margin-bottom: 25px; font-size: 14.5px;">
            <strong>🏢 Droit à la prise :</strong> {content.logisticsAlert}
          </div>

          <h2>Le Droit à la Prise en copropriété à {commune.nom}</h2>
          <p>
            {content.populationTierContent}
          </p>
          <p>
            {content.useCaseText}
          </p>

          <!-- Interactive Subsidy Calculator for Copropriété -->
          <div style="background: var(--primary-light); border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 25px; margin: 35px 0;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 18px; border-bottom: 2px solid var(--border-color); padding-bottom: 8px; margin-bottom: 15px;">💰 Simulateur de budget en copropriété (2026)</h3>
            <p style="font-size: 13.5px; color: var(--text-muted); margin-bottom: 15px;">Estimez précisément le reste à charge pour équiper votre place de parking à {commune.nom} :</p>
            
            <div style="margin-bottom: 15px;">
              <label style="display: block; font-size: 12.5px; font-weight: bold; color: var(--primary); margin-bottom: 5px;">Devis estimatif de l'électricien IRVE (€ TTC) :</label>
              <input type="range" id="priceRange" min="1200" max="3000" step="100" value="1800" style="width: 100%; accent-color: var(--accent);" />
              <div style="display: flex; justify-content: space-between; font-size: 12px; color: var(--text-muted); margin-top: 5px;">
                <span>1 200 €</span>
                <span id="priceDisplay" style="font-weight: bold; color: var(--primary); font-size: 14px;">1 800 € TTC</span>
                <span>3 000 €</span>
              </div>
            </div>
            
            <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; font-size: 13.5px; display: flex; flex-direction: column; gap: 8px; box-shadow: var(--shadow-sm);">
              <div style="display: flex; justify-content: space-between;">
                <span>Prix de l'installation :</span>
                <span id="initialPrice" style="font-weight: bold;">1 800.00 €</span>
              </div>
              <div style="display: flex; justify-content: space-between; color: var(--success);">
                <span>Prime ADVENIR Copropriété (50% plafonnée) :</span>
                <span id="advenirDiscount" style="font-weight: bold;">- 900.00 €</span>
              </div>
              <div style="display: flex; justify-content: space-between; color: var(--success);">
                <span>Crédit d'impôt pilotable :</span>
                <span style="font-weight: bold;">- 500.00 €</span>
              </div>
              <div style="display: flex; justify-content: space-between; font-size: 16px; font-weight: 800; color: var(--primary); border-top: 2px solid var(--border-color); padding-top: 8px; margin-top: 5px;">
                <span>Reste à charge réel final :</span>
                <span id="finalCoproPrice">400.00 €</span>
              </div>
            </div>
          </div>

          <h2>Tarifs moyens constatés à {commune.nom}</h2>
          <p>
            {content.pricesContext} {content.tableIntro}
          </p>

          <div class="table-scroll-wrapper">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Prestation en Copropriété</th>
                  <th>Puissance</th>
                  <th>Spécification technique</th>
                  <th>Tarif moyen posé TTC</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>Pose borne individuelle sur services généraux</strong></td>
                  <td>7.4 kW</td>
                  <td>Avec sous-compteur MID individuel</td>
                  <td class="price">{prices.copro.min}€ – {prices.copro.max}€</td>
                </tr>
                <tr>
                  <td><strong>Pose borne individuelle sur colonne Enedis</strong></td>
                  <td>7.4 kW</td>
                  <td>Liée à votre propre compteur Linky</td>
                  <td class="price" style="color: var(--accent-hover); font-weight: 800;">{Math.round(prices.copro.min * 1.15)}€ – {Math.round(prices.copro.max * 1.15)}€</td>
                </tr>
                <tr>
                  <td><strong>Étude technique infrastructure collective</strong></td>
                  <td>Variable</td>
                  <td>Dimensionnement du TGBT par Bureau d'Étude</td>
                  <td class="price">500€ – 1 200€</td>
                </tr>
                <tr>
                  <td><strong>Abonnement supervision / facturation</strong></td>
                  <td>Sans objet</td>
                  <td>Service de télé-relève mensuelle tiers</td>
                  <td class="price">5€ – 15€ / mois</td>
                </tr>
              </tbody>
            </table>
          </div>

          <p style="font-size: 13.5px; color: var(--text-muted); font-style: italic; margin-top: 10px;">
            {content.sourcesCitation}
          </p>

          <h2>Raccordement collectif et Enedis à {commune.nom}</h2>
          <p>
            {content.densiteAnalysis}
          </p>
          <p>
            {content.specificiteElectrique} {content.distanceNantesContext} {content.mobiliteContext}
          </p>

          <h2>Patrimoine immobilier &amp; Plus-value verte</h2>
          <p>
            {content.anecdotePatrimoine}
          </p>
          <p>
            {content.realEstateInsight} {content.marcheImmobilierInsight}
          </p>

          <h2>Démarches administratives et AG de copropriété</h2>
          <p>
            {content.localRegulation} {content.expertTip}
          </p>

          <blockquote style="border-left: 4px solid var(--secondary); background: var(--primary-light); padding: 15px; border-radius: var(--radius-sm); font-size: 14px; margin: 20px 0;">
            🌱 <strong>Conseil technique copropriété :</strong> {content.expertBlockquote}
          </blockquote>

          <h2>Contexte territorial &amp; Intercommunalité</h2>
          <p>
            {content.intercommunaliteContext}
          </p>
          <p>
            {content.profilCommuneInsight}
          </p>

          <!-- Embed Google Maps -->
          <h3>Localisation de nos interventions à {commune.nom}</h3>
          <CityMap cityName={commune.nom} zip={commune.codePostal} />

          <!-- FAQ Accordion -->
          <h2 style="margin-top: 40px;">FAQ : Recharge en Copropriété à {commune.nom}</h2>
          <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 20px;">
            {content.faqItems.map((faq) => (
              <details class="faq-details">
                <summary>{faq.question}</summary>
                <div class="faq-answer">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>

          <!-- External links section -->
          <div style="background: var(--primary-light); border: 1px solid var(--border-color); padding: 25px; border-radius: var(--radius-md); margin-top: 40px;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 16.5px; border-bottom: 2px solid var(--border-color); padding-bottom: 8px; margin-bottom: 15px;">🌐 Sources techniques &amp; Liens officiels</h3>
            <ul style="list-style: none; padding-left: 0; display: flex; flex-direction: column; gap: 12px; font-size: 13.5px; margin-bottom: 0;">
              {content.externalLinks.map((link) => (
                <li>
                  🔗 <a href={link.url} target="_blank" rel="noopener noreferrer" style="font-weight: bold; color: var(--secondary);">{link.label}</a> — {link.description}
                </li>
              ))}
            </ul>
          </div>

          <!-- Internal links to other articles -->
          <div style="background: white; border: 1px solid var(--border-color); padding: 25px; border-radius: var(--radius-md); margin-top: 25px;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 16.5px; border-bottom: 2px solid var(--primary-light); padding-bottom: 8px; margin-bottom: 15px;">📚 Nos Guides d'Installation en Loire-Atlantique</h3>
            <div style="display: grid; grid-template-columns: 1fr; gap: 12px;">
              {content.guideLinks.map((guide) => (
                <a href={guide.href} style="display: block; border-bottom: 1px solid var(--primary-light); padding-bottom: 8px; color: var(--text); transition: var(--transition);">
                  <strong style="color: var(--accent); display: block; font-size: 14.5px;">{guide.label} &rarr;</strong>
                  <span style="font-size: 12.5px; color: var(--text-muted);">{guide.desc}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Right Column: Lead Form & Sticky Widget -->
        <aside class="static-sidebar">
          <div id="devis" class="form-card">
            <h2>Estimez vos Aides Gratuites</h2>
            <p class="subtitle">Réponse sous 48 heures de nos artisans IRVE</p>
            <StepsForm initialCommune={commune.nom} initialZip={commune.codePostal} />
          </div>

          <div class="sidebar-widget bg-purple-gradient">
            <h3>🏢 Prime ADVENIR 2026</h3>
            <p>La prime ADVENIR pour l'habitat collectif finance 50% de la pose de votre borne, déduite directement du devis final de nos artisans partenaires.</p>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px; font-size: 12px; margin-top: 10px;">
              <li>⚡ **Aide individuelle jusqu'à 960 €**</li>
              <li>🏢 **Solutions colonnes collectives**</li>
              <li>⚖️ **Assistance syndic et AG**</li>
            </ul>
          </div>

          <!-- Link to other page templates -->
          <div class="sidebar-widget">
            <h3>🏢 Autres Prestations</h3>
            <p style="font-size: 13px; margin-bottom: 12px;">Découvrez nos solutions adaptées selon votre logement et vos besoins de charge :</p>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; font-size: 13.5px;">
              <li>
                <a href={`/installateur-borne-recharge-${commune.slug}/`} style="font-weight: 700; color: var(--secondary);">🔌 Installation en maison individuelle à {commune.nom} &rarr;</a>
              </li>
              <li>
                <a href={`/wallbox-${commune.slug}/`} style="font-weight: 700; color: var(--secondary);">⚡ Comparatif Wallbox à {commune.nom} &rarr;</a>
              </li>
            </ul>
          </div>
        </aside>
      </div>

      <!-- Neighbor links section - Interlinking -->
      <div style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 35px; margin-top: 40px; box-shadow: var(--shadow-sm);">
        <h3 style="font-family: var(--font-heading); font-size: 20px; color: var(--primary); margin-bottom: 5px; text-align: center;">🏢 Bornes en Copropriété à proximité de {commune.nom}</h3>
        <p style="font-size: 13.5px; color: var(--text-muted); text-align: center; margin-bottom: 25px;">Retrouvez nos techniciens qualifiés dans les communes voisines en Loire-Atlantique :</p>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 12px;">
          {nearby.map((c) => (
            <a href={`/borne-recharge-copropriete-${c.slug}/`} style="background: var(--bg); border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 12px 15px; font-size: 13px; font-weight: 600; display: flex; justify-content: space-between; align-items: center; transition: var(--transition); color: var(--primary);">
              <span>{c.nom} <span style="font-size: 10px; font-weight: normal; color: var(--text-muted);">({c.codePostal})</span></span>
              <span style="color: var(--accent-hover);">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  // Dynamic copropriété price slider logic
  const priceRange = document.getElementById('priceRange');
  const priceDisplay = document.getElementById('priceDisplay');
  const initialPrice = document.getElementById('initialPrice');
  const advenirDiscount = document.getElementById('advenirDiscount');
  const finalCoproPrice = document.getElementById('finalCoproPrice');

  function updateCoproCalculator() {
    if (!priceRange || !priceDisplay || !initialPrice || !advenirDiscount || !finalCoproPrice) return;
    
    const price = parseFloat(priceRange.value);
    priceDisplay.textContent = price.toLocaleString('fr-FR') + ' € TTC';
    initialPrice.textContent = price.toFixed(2) + ' €';
    
    // ADVENIR is 50% of price capped at 960 €
    const advenir = Math.min(price * 0.50, 960);
    const taxCredit = 500;
    const finalPrice = price - advenir - taxCredit;
    
    advenirDiscount.textContent = '- ' + advenir.toFixed(2) + ' €';
    finalCoproPrice.textContent = finalPrice.toFixed(2) + ' €';
  }

  if (priceRange) {
    priceRange.addEventListener('input', updateCoproCalculator);
    // Initial call
    updateCoproCalculator();
  }
</script>

<style>
  @media (max-width: 992px) {
    .two-column-layout {
      grid-template-columns: 1fr !important;
      gap: 25px;
    }
    .local-stats-cards-section div[style*="grid-template-columns"] {
      grid-template-columns: 1fr 1fr !important;
      gap: 10px;
    }
  }
  @media (max-width: 576px) {
    .local-stats-cards-section div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
