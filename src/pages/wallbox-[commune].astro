---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import CityMap from '../components/CityMap.astro';
import StepsForm from '../components/StepsForm.astro';
import communes from '../data/communes.json';
import { generateCommuneContent, type Commune, getDynamicPrices } from '../lib/contentEngine';
import { getSmartNearbyCommunes } from '../lib/geoLinks';
import config from '../data/config.json';

export async function getStaticPaths() {
  return communes.map((commune) => ({
    params: { commune: commune.slug },
    props: { commune }
  }));
}

interface Props {
  commune: Commune;
}

const { commune } = Astro.props;
const content = generateCommuneContent(commune, 'wallbox');
const nearby = getSmartNearbyCommunes(commune.slug, communes);
const prices = getDynamicPrices(commune);

const title = `Quelle Wallbox Installer à ${commune.nom} (${commune.codePostal}) ? Devis & Comparatif 2026`;
const description = content.introParagraph;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes", href: "/communes/" },
  { label: `${commune.nom} (Modèles Wallbox)` }
];
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    faqItems={content.faqItems}
    breadcrumbItems={breadcrumbItems}
    communeName={commune.nom}
    zipCode={commune.codePostal}
    cityName={commune.nom}
  />

  <Breadcrumb items={breadcrumbItems} />

  <!-- Hero Banner -->
  <section class="local-hero-banner" style="background: linear-gradient(135deg, #022c22 0%, #064e3b 100%); color: white; padding: 50px 0; border-bottom: 5px solid var(--secondary);">
    <div class="container">
      <div style="max-width: 900px;">
        <span class="hero-badge">⚡ Comparatif Wallbox Clés en main 2026</span>
        <h1 style="color: white; font-family: var(--font-heading); font-size: 34px; margin-top: 10px; margin-bottom: 15px; line-height: 1.2;">
          Quelle Wallbox Installer à {commune.nom} ({commune.codePostal}) ?
        </h1>
        <p style="color: var(--primary-light); font-size: 16.5px; line-height: 1.5; margin-bottom: 0;">
          {content.introParagraph}
        </p>
      </div>
    </div>
  </section>

  <!-- Local Stats Cards -->
  <section class="local-stats-cards-section" style="padding: 30px 0; background: var(--primary-light); border-bottom: 1px solid var(--border-color);">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px;">
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">🚀</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">7.4 kW à 22 kW</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Gamme de puissance</span>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">📲</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">Connectée / Smart</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Suivi conso mobile</span>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">🌿</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">Écoresponsable</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Matériaux recyclés</span>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">🛡️</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">IP65 / IK10</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Protection intempéries</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content & Form Layout -->
  <section class="two-column-layout-section" style="padding: 50px 0; background-color: var(--bg);">
    <div class="container">
      <div class="two-column-layout">
        
        <!-- Left Column: Content -->
        <div class="static-main-content" style="background: var(--card-bg); padding: 40px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);">
          
          <!-- Alert Box -->
          <div style="border-left: 4px solid var(--accent); background: var(--primary-light); padding: 15px 20px; border-radius: var(--radius-sm); margin-bottom: 25px; font-size: 14.5px;">
            <strong>⚡ Choix du chargeur :</strong> {content.logisticsAlert}
          </div>

          <h2>Comparer les modèles de Wallbox à {commune.nom}</h2>
          <p>
            {content.populationTierContent}
          </p>
          <p>
            {content.useCaseText}
          </p>

          <!-- Interactive Brand selector -->
          <div style="background: var(--primary-light); border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 25px; margin: 35px 0;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 18px; border-bottom: 2px solid var(--border-color); padding-bottom: 8px; margin-bottom: 15px;">🔍 Comparateur de grandes marques de Wallbox</h3>
            <p style="font-size: 13.5px; color: var(--text-muted); margin-bottom: 15px;">Sélectionnez une marque pour voir ses caractéristiques, sa puissance et son prix indicatif posé à {commune.nom} :</p>
            
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 15px;">
              <button id="btnEasee" class="btn-secondary" style="padding: 8px; font-size: 12.5px; font-weight: bold; background: var(--border-color);">Easee One</button>
              <button id="btnCopper" class="btn-secondary" style="padding: 8px; font-size: 12.5px; font-weight: bold; background: white;">Wallbox Copper</button>
              <button id="btnSchneider" class="btn-secondary" style="padding: 8px; font-size: 12.5px; font-weight: bold; background: white;">Schneider EVlink</button>
            </div>
            
            <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; font-size: 13.5px; display: flex; flex-direction: column; gap: 8px; box-shadow: var(--shadow-sm);">
              <div style="display: flex; justify-content: space-between;">
                <span>Modèle sélectionné :</span>
                <strong id="modelName">Easee One (Norvège)</strong>
              </div>
              <div style="display: flex; justify-content: space-between;">
                <span>Puissance maximale :</span>
                <span id="modelPower" style="font-weight: bold;">7.4 kW (Monophasé)</span>
              </div>
              <div style="display: flex; justify-content: space-between;">
                <span>Points forts :</span>
                <span id="modelHighlights" style="font-weight: bold; color: var(--primary);">Design compact, Smart charging intégré, RFID</span>
              </div>
              <div style="display: flex; justify-content: space-between; font-size: 15px; font-weight: 800; color: var(--accent-hover); border-top: 1.5px solid var(--primary-light); padding-top: 8px;">
                <span>Tarif moyen posé estimé :</span>
                <span id="modelPrice">{prices.wallbox7kW.min + 100} € – {prices.wallbox7kW.max} € TTC</span>
              </div>
            </div>
          </div>

          <h2>Tarifs détaillés et puissance de charge à {commune.nom}</h2>
          <p>
            {content.pricesContext} {content.tableIntro}
          </p>

          <div class="table-scroll-wrapper">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Modèle de Wallbox</th>
                  <th>Puissance</th>
                  <th>Spécificités techniques</th>
                  <th>Tarif moyen posé TTC</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>Prise renforcée Green'Up</strong></td>
                  <td>3.7 kW (16A)</td>
                  <td>Recharge lente sécurisée</td>
                  <td class="price">{prices.greenUp.min}€ – {prices.greenUp.max}€</td>
                </tr>
                <tr>
                  <td><strong>Wallbox 7.4 kW monophasé</strong></td>
                  <td>7.4 kW (32A)</td>
                  <td><strong>Recharge complète en 7-8h</strong></td>
                  <td class="price" style="color: var(--accent-hover); font-weight: 800;">{prices.wallbox7kW.min}€ – {prices.wallbox7kW.max}€</td>
                </tr>
                <tr>
                  <td><strong>Wallbox 11 kW triphasé</strong></td>
                  <td>11 kW (3x16A)</td>
                  <td>Recharge semi-rapide en 4-5h</td>
                  <td class="price">{prices.wallbox11kW.min}€ – {prices.wallbox11kW.max}€</td>
                </tr>
                <tr>
                  <td><strong>Wallbox 22 kW triphasé</strong></td>
                  <td>22 kW (3x32A)</td>
                  <td>Recharge rapide en 1-2h</td>
                  <td class="price">{prices.wallbox22kW.min}€ – {prices.wallbox22kW.max}€</td>
                </tr>
              </tbody>
            </table>
          </div>

          <p style="font-size: 13.5px; color: var(--text-muted); font-style: italic; margin-top: 10px;">
            {content.sourcesCitation}
          </p>

          <h2>Données marché et Transition à {commune.nom}</h2>
          <p>
            {content.densiteAnalysis}
          </p>
          <p>
            {content.specificiteElectrique} {content.distanceNantesContext} {content.mobiliteContext}
          </p>

          <h2>Valorisation immobilière de votre villa ou maison</h2>
          <p>
            {content.anecdotePatrimoine}
          </p>
          <p>
            {content.realEstateInsight} {content.marcheImmobilierInsight}
          </p>

          <h2>Réglementations de pose et normes de sécurité</h2>
          <p>
            {content.localRegulation} {content.expertTip}
          </p>

          <blockquote style="border-left: 4px solid var(--secondary); background: var(--primary-light); padding: 15px; border-radius: var(--radius-sm); font-size: 14px; margin: 20px 0;">
            🌱 <strong>Conseil technique wallbox :</strong> {content.expertBlockquote}
          </blockquote>

          <h2>Contexte territorial &amp; Intercommunalité</h2>
          <p>
            {content.intercommunaliteContext}
          </p>
          <p>
            {content.profilCommuneInsight}
          </p>

          <!-- Embed Google Maps -->
          <h3>Localisation de nos interventions à {commune.nom}</h3>
          <CityMap cityName={commune.nom} zip={commune.codePostal} />

          <!-- FAQ Accordion -->
          <h2 style="margin-top: 40px;">FAQ : Comparatif et Choix de Wallbox à {commune.nom}</h2>
          <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 20px;">
            {content.faqItems.map((faq) => (
              <details class="faq-details">
                <summary>{faq.question}</summary>
                <div class="faq-answer">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>

          <!-- External links section -->
          <div style="background: var(--primary-light); border: 1px solid var(--border-color); padding: 25px; border-radius: var(--radius-md); margin-top: 40px;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 16.5px; border-bottom: 2px solid var(--border-color); padding-bottom: 8px; margin-bottom: 15px;">🌐 Sources techniques &amp; Liens officiels</h3>
            <ul style="list-style: none; padding-left: 0; display: flex; flex-direction: column; gap: 12px; font-size: 13.5px; margin-bottom: 0;">
              {content.externalLinks.map((link) => (
                <li>
                  🔗 <a href={link.url} target="_blank" rel="noopener noreferrer" style="font-weight: bold; color: var(--secondary);">{link.label}</a> — {link.description}
                </li>
              ))}
            </ul>
          </div>

          <!-- Internal links to other articles -->
          <div style="background: white; border: 1px solid var(--border-color); padding: 25px; border-radius: var(--radius-md); margin-top: 25px;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 16.5px; border-bottom: 2px solid var(--primary-light); padding-bottom: 8px; margin-bottom: 15px;">📚 Nos Guides d'Installation en Loire-Atlantique</h3>
            <div style="display: grid; grid-template-columns: 1fr; gap: 12px;">
              {content.guideLinks.map((guide) => (
                <a href={guide.href} style="display: block; border-bottom: 1px solid var(--primary-light); padding-bottom: 8px; color: var(--text); transition: var(--transition);">
                  <strong style="color: var(--accent); display: block; font-size: 14.5px;">{guide.label} &rarr;</strong>
                  <span style="font-size: 12.5px; color: var(--text-muted);">{guide.desc}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Right Column: Lead Form & Sticky Widget -->
        <aside class="static-sidebar">
          <div id="devis" class="form-card">
            <h2>Estimez vos Aides Gratuites</h2>
            <p class="subtitle">Réponse sous 48 heures de nos artisans IRVE</p>
            <StepsForm initialCommune={commune.nom} initialZip={commune.codePostal} />
          </div>

          <div class="sidebar-widget bg-purple-gradient">
            <h3>⚡ Wallbox Connectée</h3>
            <p>Profitez d'un crédit d'impôt de 500 € pour la pose d'une borne intelligente pilotable, géré directement par nos électriciens qualifiés RGE IRVE.</p>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px; font-size: 12px; margin-top: 10px;">
              <li>⚡ **Délestage dynamique intelligent**</li>
              <li>📲 **Programmation heures creuses**</li>
              <li>🔒 **Verrouillage d'accès RFID**</li>
            </ul>
          </div>

          <!-- Link to other page templates -->
          <div class="sidebar-widget">
            <h3>🏢 Liens Utiles</h3>
            <p style="font-size: 13px; margin-bottom: 12px;">Découvrez nos solutions adaptées selon votre logement et vos besoins de charge :</p>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; font-size: 13.5px;">
              <li>
                <a href={`/installateur-borne-recharge-${commune.slug}/`} style="font-weight: 700; color: var(--secondary);">🔌 Installation à domicile à {commune.nom} &rarr;</a>
              </li>
              <li>
                <a href={`/borne-recharge-copropriete-${commune.slug}/`} style="font-weight: 700; color: var(--secondary);">🏢 Raccordement en copropriété à {commune.nom} &rarr;</a>
              </li>
            </ul>
          </div>
        </aside>
      </div>

      <!-- Neighbor links section - Interlinking -->
      <div style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 35px; margin-top: 40px; box-shadow: var(--shadow-sm);">
        <h3 style="font-family: var(--font-heading); font-size: 20px; color: var(--primary); margin-bottom: 5px; text-align: center;">⚡ Bornes Wallbox à proximité de {commune.nom}</h3>
        <p style="font-size: 13.5px; color: var(--text-muted); text-align: center; margin-bottom: 25px;">Retrouvez nos techniciens qualifiés dans les communes voisines en Loire-Atlantique :</p>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 12px;">
          {nearby.map((c) => (
            <a href={`/wallbox-${c.slug}/`} style="background: var(--bg); border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 12px 15px; font-size: 13px; font-weight: 600; display: flex; justify-content: space-between; align-items: center; transition: var(--transition); color: var(--primary);">
              <span>{c.nom} <span style="font-size: 10px; font-weight: normal; color: var(--text-muted);">({c.codePostal})</span></span>
              <span style="color: var(--accent-hover);">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline define:vars={{ min7: prices.wallbox7kW.min, max7: prices.wallbox7kW.max, min11: prices.wallbox11kW.min, max11: prices.wallbox11kW.max, min22: prices.wallbox22kW.min, max22: prices.wallbox22kW.max }}>
  // Brand comparison tabs logic
  const btnEasee = document.getElementById('btnEasee');
  const btnCopper = document.getElementById('btnCopper');
  const btnSchneider = document.getElementById('btnSchneider');
  
  const modelName = document.getElementById('modelName');
  const modelPower = document.getElementById('modelPower');
  const modelHighlights = document.getElementById('modelHighlights');
  const modelPrice = document.getElementById('modelPrice');

  function updateModelTab(brand) {
    if (!btnEasee || !btnCopper || !btnSchneider || !modelName || !modelPower || !modelHighlights || !modelPrice) return;
    
    // Set all buttons to white bg
    btnEasee.style.background = 'white';
    btnCopper.style.background = 'white';
    btnSchneider.style.background = 'white';

    if (brand === 'easee') {
      btnEasee.style.background = 'var(--border-color)';
      modelName.textContent = 'Easee One (Norvège)';
      modelPower.textContent = '1.4 kW à 7.4 kW (Monophasé)';
      modelHighlights.textContent = 'Format ultra-compact, Smart charging, lecteur RFID, garantie 3 ans.';
      modelPrice.textContent = (min7 + 100) + ' € – ' + max7 + ' € TTC posé';
    } else if (brand === 'copper') {
      btnCopper.style.background = 'var(--border-color)';
      modelName.textContent = 'Wallbox Copper SB (Espagne)';
      modelPower.textContent = '1.4 kW à 22 kW (Monophasé & Triphasé)';
      modelHighlights.textContent = 'Prise T2S intégrée, réglage d\'intensité, Bluetooth, Wi-Fi, lecteur de badge.';
      modelPrice.textContent = (min11 + 100) + ' € – ' + max22 + ' € TTC posé';
    } else {
      btnSchneider.style.background = 'var(--border-color)';
      modelName.textContent = 'Schneider EVlink Home (France)';
      modelPower.textContent = '3.7 kW à 11 kW (Monophasé & Triphasé)';
      modelHighlights.textContent = 'Robustesse Schneider, délestage Linky intégré par fil pilote, sécurité maximale.';
      modelPrice.textContent = min7 + ' € – ' + max11 + ' € TTC posé';
    }
  }

  if (btnEasee && btnCopper && btnSchneider) {
    btnEasee.addEventListener('click', () => updateModelTab('easee'));
    btnCopper.addEventListener('click', () => updateModelTab('copper'));
    btnSchneider.addEventListener('click', () => updateModelTab('schneider'));
  }
</script>

<style>
  @media (max-width: 992px) {
    .two-column-layout {
      grid-template-columns: 1fr !important;
      gap: 25px;
    }
    .local-stats-cards-section div[style*="grid-template-columns"] {
      grid-template-columns: 1fr 1fr !important;
      gap: 10px;
    }
  }
  @media (max-width: 576px) {
    .local-stats-cards-section div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
