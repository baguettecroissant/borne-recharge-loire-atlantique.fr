---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import CityMap from '../components/CityMap.astro';
import StepsForm from '../components/StepsForm.astro';
import communes from '../data/communes.json';
import { generateCommuneContent, type Commune, getDynamicPrices } from '../lib/contentEngine';
import { getSmartNearbyCommunes } from '../lib/geoLinks';
import config from '../data/config.json';

export async function getStaticPaths() {
  return communes.map((commune) => ({
    params: { commune: commune.slug },
    props: { commune }
  }));
}

interface Props {
  commune: Commune;
}

const { commune } = Astro.props;
const content = generateCommuneContent(commune, 'main');
const nearby = getSmartNearbyCommunes(commune.slug, communes);
const prices = getDynamicPrices(commune);

const title = `Installateur Borne de Recharge à ${commune.nom} (${commune.codePostal}) — Électricien IRVE`;
const description = content.introParagraph;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes", href: "/communes/" },
  { label: commune.nom }
];
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    faqItems={content.faqItems}
    breadcrumbItems={breadcrumbItems}
    communeName={commune.nom}
    zipCode={commune.codePostal}
    cityName={commune.nom}
  />

  <Breadcrumb items={breadcrumbItems} />

  <!-- Hero Local Banner -->
  <section class="local-hero-banner" style="background: linear-gradient(135deg, #022c22 0%, #064e3b 100%); color: white; padding: 50px 0; border-bottom: 5px solid var(--secondary);">
    <div class="container">
      <div style="max-width: 900px;">
        <span class="hero-badge">🌿 Électriciens IRVE Certifiés 2026</span>
        <h1 style="color: white; font-family: var(--font-heading); font-size: 34px; margin-top: 10px; margin-bottom: 15px; line-height: 1.2;">
          Installateur Borne de Recharge à {commune.nom} ({commune.codePostal})
        </h1>
        <p style="color: var(--primary-light); font-size: 16.5px; line-height: 1.5; margin-bottom: 0;">
          {content.introParagraph}
        </p>
      </div>
    </div>
  </section>

  <!-- Local Stats Cards -->
  <section class="local-stats-cards-section" style="padding: 30px 0; background: var(--primary-light); border-bottom: 1px solid var(--border-color);">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px;">
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">📈</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">+{commune.croissanceVE}% / an</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Croissance des VE à {commune.nom}</span>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">🏡</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">{commune.logementsMaison}%</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Maisons individuelles</span>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">🚗</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">{commune.vehiculesElectriques?.toLocaleString() || '150'} VE</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Estimés sur la commune</span>
        </div>
        <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
          <span style="display: block; font-size: 24px; margin-bottom: 4px;">⚡</span>
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: var(--primary); display: block; line-height: 1.1;">{commune.bornesPubliques || '5'} bornes</span>
          <span style="font-size: 11.5px; color: var(--text-muted);">Réseau public communal</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Two Column Layout -->
  <section class="two-column-layout-section" style="padding: 50px 0; background-color: var(--bg);">
    <div class="container">
      <div class="two-column-layout">
        
        <!-- Left Column: Content -->
        <div class="static-main-content" style="background: var(--card-bg); padding: 40px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);">
          
          <!-- Alert Box -->
          <div style="border-left: 4px solid var(--accent); background: var(--primary-light); padding: 15px 20px; border-radius: var(--radius-sm); margin-bottom: 25px; font-size: 14.5px;">
            <strong>⚠️ Information chantier :</strong> {content.logisticsAlert}
          </div>

          <h2>Pourquoi installer une borne de recharge à {commune.nom} ?</h2>
          <p>
            {content.populationTierContent}
          </p>
          <p>
            {content.useCaseText}
          </p>

          <!-- Interactive Calculator -->
          <div style="background: var(--primary-light); border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 25px; margin: 35px 0;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 18px; border-bottom: 2px solid var(--border-color); padding-bottom: 8px; margin-bottom: 15px;">🧮 Simulateur de Temps de Charge à {commune.nom}</h3>
            <p style="font-size: 13.5px; color: var(--text-muted); margin-bottom: 15px;">Sélectionnez la capacité de votre batterie et la puissance de la borne pour calculer la durée estimée d'une charge complète (0 à 100%) :</p>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
              <div>
                <label style="display: block; font-size: 12.5px; font-weight: bold; color: var(--primary); margin-bottom: 5px;">Capacité Batterie (VE) :</label>
                <select id="batterySelect" class="form-control" style="background: white; border: 1px solid var(--border-color); padding: 8px 10px; border-radius: 4px; font-size: 13.5px; width: 100%;">
                  <option value="45">45 kWh (Renault Zoé, e-208)</option>
                  <option value="60" selected>60 kWh (Tesla Model 3, e-3008)</option>
                  <option value="75">75 kWh (Tesla Model Y Grand Autonomie)</option>
                  <option value="100">100 kWh (Porsche Taycan, Tesla Model S)</option>
                </select>
              </div>
              <div>
                <label style="display: block; font-size: 12.5px; font-weight: bold; color: var(--primary); margin-bottom: 5px;">Puissance de charge :</label>
                <select id="powerSelect" class="form-control" style="background: white; border: 1px solid var(--border-color); padding: 8px 10px; border-radius: 4px; font-size: 13.5px; width: 100%;">
                  <option value="2.3">Prise standard 2.3 kW (10A)</option>
                  <option value="3.7">Prise renforcée 3.7 kW (16A)</option>
                  <option value="7.4" selected>Wallbox 7.4 kW (32A) Monophasée</option>
                  <option value="11">Wallbox 11 kW Triphasée</option>
                  <option value="22">Wallbox 22 kW Triphasée</option>
                </select>
              </div>
            </div>
            
            <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; text-align: center; box-shadow: var(--shadow-sm);">
              <span style="font-size: 13px; color: var(--text-muted); display: block;">Temps de charge estimé :</span>
              <span id="chargeResult" style="font-family: var(--font-heading); font-size: 26px; font-weight: 800; color: var(--accent-hover);">8h 06min</span>
              <span style="font-size: 11px; color: var(--text-muted); display: block; margin-top: 4px;">*Efficacité de charge estimée à 90% pour pertes thermiques de raccordement.</span>
            </div>
          </div>

          <h2>Tarifs d'installation 2026 à {commune.nom} (Loire-Atlantique)</h2>
          <p>
            {content.pricesContext} {content.tableIntro}
          </p>

          <div class="table-scroll-wrapper">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Type d'équipement</th>
                  <th>Puissance</th>
                  <th>Utilisation conseillée</th>
                  <th>Tarif moyen posé TTC</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>Prise renforcée Green'Up</strong></td>
                  <td>3.7 kW (16A)</td>
                  <td>VE Hybrides &amp; charges lentes</td>
                  <td class="price">{prices.greenUp.min}€ – {prices.greenUp.max}€</td>
                </tr>
                <tr>
                  <td><strong>Wallbox 7 kW monophasé</strong></td>
                  <td>7.4 kW (32A)</td>
                  <td><strong>Standard résidentiel (maison)</strong></td>
                  <td class="price" style="color: var(--accent-hover); font-weight: 800;">{prices.wallbox7kW.min}€ – {prices.wallbox7kW.max}€</td>
                </tr>
                <tr>
                  <td><strong>Wallbox 11 kW triphasé</strong></td>
                  <td>11 kW (3x16A)</td>
                  <td>Semi-rapide (compteur triphasé)</td>
                  <td class="price">{prices.wallbox11kW.min}€ – {prices.wallbox11kW.max}€</td>
                </tr>
                <tr>
                  <td><strong>Wallbox 22 kW triphasé</strong></td>
                  <td>22 kW (3x32A)</td>
                  <td>Rapide (villas, commerces)</td>
                  <td class="price">{prices.wallbox22kW.min}€ – {prices.wallbox22kW.max}€</td>
                </tr>
                <tr>
                  <td><strong>Borne en copropriété</strong></td>
                  <td>7.4 kW</td>
                  <td>Place de parking collective</td>
                  <td class="price">{prices.copro.min}€ – {prices.copro.max}€</td>
                </tr>
              </tbody>
            </table>
          </div>

          <p style="font-size: 13.5px; color: var(--text-muted); font-style: italic; margin-top: 10px;">
            {content.sourcesCitation}
          </p>

          <h2>Données locales &amp; Mobilité à {commune.nom}</h2>
          <p>
            {content.densiteAnalysis}
          </p>
          <p>
            {content.specificiteElectrique} {content.distanceNantesContext} {content.mobiliteContext}
          </p>

          <h2>Spécificités géologiques &amp; Patrimoine</h2>
          <p>
            {content.anecdotePatrimoine}
          </p>
          <blockquote style="border-left: 4px solid var(--secondary); background: var(--primary-light); padding: 15px; border-radius: var(--radius-sm); font-size: 14px; margin: 20px 0;">
            🌱 <strong>Conseil technique local :</strong> {content.expertBlockquote}
          </blockquote>
          <p>
            {content.realEstateInsight} {content.marcheImmobilierInsight}
          </p>

          <h2>Contexte territorial &amp; Intercommunalité</h2>
          <p>
            {content.intercommunaliteContext}
          </p>
          <p>
            {content.profilCommuneInsight}
          </p>

          <h2>Normes électriques et Réglementation locale</h2>
          <p>
            {content.localRegulation} {content.expertTip}
          </p>

          <!-- Interactive simulator for ADVENIR -->
          <div style="background: var(--bg); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 25px; margin: 30px 0;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 17px; font-weight: bold;">💰 Simulateur de subventions ADVENIR &amp; État 2026</h3>
            <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 15px;">Sélectionnez votre type de logement pour estimer le reste à charge sur une installation de 1 500 € TTC :</p>
            
            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
              <button id="btnHouse" class="btn-secondary" style="flex: 1; padding: 10px; font-size: 13px; font-weight: bold; background: var(--border-color);">🏡 Maison Individuelle</button>
              <button id="btnCopro" class="btn-secondary" style="flex: 1; padding: 10px; font-size: 13px; font-weight: bold; background: white;">🏢 Copropriété (Appartement)</button>
            </div>
            
            <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; font-size: 13.5px; display: flex; flex-direction: column; gap: 8px;">
              <div style="display: flex; justify-content: space-between;">
                <span>Prix d'installation de base :</span>
                <strong>1 500.00 €</strong>
              </div>
              <div style="display: flex; justify-content: space-between; color: var(--success);">
                <span>Crédit d'impôt État (Taux 2026) :</span>
                <strong id="simTaxCredit">- 500.00 €</strong>
              </div>
              <div style="display: flex; justify-content: space-between; color: var(--success);">
                <span>Aide ADVENIR 44 :</span>
                <strong id="simAdvenir">- 0.00 €</strong>
              </div>
              <div style="display: flex; justify-content: space-between; color: var(--success); font-weight: bold; border-top: 1.5px solid var(--primary-light); padding-top: 8px;">
                <span>TVA appliquée :</span>
                <span>5,5% (incluse)</span>
              </div>
              <div style="display: flex; justify-content: space-between; font-size: 16px; font-weight: 800; color: var(--primary); border-top: 2px solid var(--border-color); padding-top: 8px;">
                <span>Reste à charge réel :</span>
                <span id="simResult">1 000.00 €</span>
              </div>
            </div>
          </div>

          <!-- Embed Google Maps -->
          <h3>Localisation de nos interventions à {commune.nom}</h3>
          <CityMap cityName={commune.nom} zip={commune.codePostal} />

          <!-- FAQ Accordion -->
          <h2 style="margin-top: 40px;">FAQ : Questions fréquentes à {commune.nom}</h2>
          <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 20px;">
            {content.faqItems.map((faq) => (
              <details class="faq-details">
                <summary>{faq.question}</summary>
                <div class="faq-answer">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>

          <!-- External links section -->
          <div style="background: var(--primary-light); border: 1px solid var(--border-color); padding: 25px; border-radius: var(--radius-md); margin-top: 40px;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 16.5px; border-bottom: 2px solid var(--border-color); padding-bottom: 8px; margin-bottom: 15px;">🌐 Sources techniques &amp; Liens officiels</h3>
            <ul style="list-style: none; padding-left: 0; display: flex; flex-direction: column; gap: 12px; font-size: 13.5px; margin-bottom: 0;">
              {content.externalLinks.map((link) => (
                <li>
                  🔗 <a href={link.url} target="_blank" rel="noopener noreferrer" style="font-weight: bold; color: var(--secondary);">{link.label}</a> — {link.description}
                </li>
              ))}
            </ul>
          </div>

          <!-- Internal links to other articles -->
          <div style="background: white; border: 1px solid var(--border-color); padding: 25px; border-radius: var(--radius-md); margin-top: 25px;">
            <h3 style="margin-top: 0; color: var(--primary); font-size: 16.5px; border-bottom: 2px solid var(--primary-light); padding-bottom: 8px; margin-bottom: 15px;">📚 Nos Guides d'Installation en Loire-Atlantique</h3>
            <div style="display: grid; grid-template-columns: 1fr; gap: 12px;">
              {content.guideLinks.map((guide) => (
                <a href={guide.href} style="display: block; border-bottom: 1px solid var(--primary-light); padding-bottom: 8px; color: var(--text); transition: var(--transition);">
                  <strong style="color: var(--accent); display: block; font-size: 14.5px;">{guide.label} &rarr;</strong>
                  <span style="font-size: 12.5px; color: var(--text-muted);">{guide.desc}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Right Column: Lead Form & Sticky Widget -->
        <aside class="static-sidebar">
          <div id="devis" class="form-card">
            <h2>Estimez vos Aides Gratuites</h2>
            <p class="subtitle">Réponse sous 48 heures de nos artisans IRVE</p>
            <StepsForm initialCommune={commune.nom} initialZip={commune.codePostal} />
          </div>

          <div class="sidebar-widget bg-purple-gradient">
            <h3>🛡️ Réseau Certifié IRVE</h3>
            <p>Tous les électriciens de notre réseau intervenant sur la commune de {commune.nom} possèdent l'agrément obligatoire pour installer votre wallbox.</p>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px; font-size: 12px; margin-top: 10px;">
              <li>⚡ **Sécurisation NF C 15-100**</li>
              <li>📑 **Attestation de conformité CONSUEL**</li>
              <li>💰 **Éligibilité Crédit d'impôt 500 €**</li>
            </ul>
          </div>

          <!-- Link to copro and wallbox pages for this town -->
          <div class="sidebar-widget">
            <h3>🏢 Liens Spécifiques</h3>
            <p style="font-size: 13px; margin-bottom: 12px;">Découvrez nos solutions adaptées selon votre logement et vos besoins de charge :</p>
            <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; font-size: 13.5px;">
              <li>
                <a href={`/borne-recharge-copropriete-${commune.slug}/`} style="font-weight: 700; color: var(--secondary);">🏢 Raccordement en copropriété à {commune.nom} &rarr;</a>
              </li>
              <li>
                <a href={`/wallbox-${commune.slug}/`} style="font-weight: 700; color: var(--secondary);">⚡ Comparatif Wallbox à {commune.nom} &rarr;</a>
              </li>
            </ul>
          </div>
        </aside>
      </div>

      <!-- Neighbor links section - Interlinking -->
      <div style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 35px; margin-top: 40px; box-shadow: var(--shadow-sm);">
        <h3 style="font-family: var(--font-heading); font-size: 20px; color: var(--primary); margin-bottom: 5px; text-align: center;">📍 Installateurs IRVE à proximité de {commune.nom}</h3>
        <p style="font-size: 13.5px; color: var(--text-muted); text-align: center; margin-bottom: 25px;">Retrouvez nos techniciens qualifiés dans les communes voisines en Loire-Atlantique :</p>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 12px;">
          {nearby.map((c) => (
            <a href={`/installateur-borne-recharge-${c.slug}/`} style="background: var(--bg); border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 12px 15px; font-size: 13px; font-weight: 600; display: flex; justify-content: space-between; align-items: center; transition: var(--transition); color: var(--primary);">
              <span>{c.nom} <span style="font-size: 10px; font-weight: normal; color: var(--text-muted);">({c.codePostal})</span></span>
              <span style="color: var(--accent-hover);">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  // Battery and power change logic
  const batterySelect = document.getElementById('batterySelect');
  const powerSelect = document.getElementById('powerSelect');
  const chargeResult = document.getElementById('chargeResult');

  function calculateChargeTime() {
    if (!batterySelect || !powerSelect || !chargeResult) return;
    const capacity = parseFloat(batterySelect.value);
    const power = parseFloat(powerSelect.value);
    
    // Time in hours = capacity / (power * 0.90 efficiency)
    const totalHours = capacity / (power * 0.90);
    const hours = Math.floor(totalHours);
    const minutes = Math.round((totalHours - hours) * 60);
    
    let resultStr = '';
    if (hours > 0) {
      resultStr += hours + 'h ';
    }
    resultStr += (minutes < 10 ? '0' : '') + minutes + 'min';
    chargeResult.textContent = resultStr;
  }

  if (batterySelect && powerSelect) {
    batterySelect.addEventListener('change', calculateChargeTime);
    powerSelect.addEventListener('change', calculateChargeTime);
  }

  // ADVENIR subsidy simulator logic
  const btnHouse = document.getElementById('btnHouse');
  const btnCopro = document.getElementById('btnCopro');
  const simTaxCredit = document.getElementById('simTaxCredit');
  const simAdvenir = document.getElementById('simAdvenir');
  const simResult = document.getElementById('simResult');

  function updateSubsidySimulator(type) {
    if (!btnHouse || !btnCopro || !simTaxCredit || !simAdvenir || !simResult) return;
    
    const initialPrice = 1500;
    const taxCredit = 500;
    
    if (type === 'house') {
      btnHouse.style.background = 'var(--border-color)';
      btnCopro.style.background = 'white';
      
      const advenir = 0;
      const finalPrice = initialPrice - taxCredit - advenir;
      
      simTaxCredit.textContent = '- 500.00 €';
      simAdvenir.textContent = '- 0.00 €';
      simResult.textContent = finalPrice.toFixed(2) + ' €';
    } else {
      btnHouse.style.background = 'white';
      btnCopro.style.background = 'var(--border-color)';
      
      // Copropriété advenir is 50% of price capped at 960 €
      const advenir = Math.min(initialPrice * 0.50, 960);
      const finalPrice = initialPrice - taxCredit - advenir;
      
      simTaxCredit.textContent = '- 500.00 €';
      simAdvenir.textContent = '- ' + advenir.toFixed(2) + ' €';
      simResult.textContent = finalPrice.toFixed(2) + ' €';
    }
  }

  if (btnHouse && btnCopro) {
    btnHouse.addEventListener('click', () => updateSubsidySimulator('house'));
    btnCopro.addEventListener('click', () => updateSubsidySimulator('copro'));
  }
</script>

<style>
  @media (max-width: 992px) {
    .two-column-layout {
      grid-template-columns: 1fr !important;
      gap: 25px;
    }
    .local-stats-cards-section div[style*="grid-template-columns"] {
      grid-template-columns: 1fr 1fr !important;
      gap: 10px;
    }
  }
  @media (max-width: 576px) {
    .local-stats-cards-section div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
